<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New place</title>
</head>
<body>
    
    <form action="/listing" method="post">
    <br><br>
    <label for="Title">Enter Title:</label>
    <input type="text" name="title" placeholder="Enter Place Name" id="Title">
    <br><br><br>
    <label for="Description">Enter Description</label>
    <textarea name="description" id="Description"></textarea>


    <br><br>
    <label for="Price">Enter Price:</label>
    <input type="number" name="price" placeholder="Enter Price" id="Price">

    <br><br>
    <label for="Title">Enter Location:</label>
    <input type="text" name="location" placeholder="Enter Location" id="Title">

    <br><br>
    <label for="country">Enter country:</label>
    <input type="text" name="country" placeholder="Enter Location" id="country">
    <br><br>
    <label for="image">Enter image:</label>
    <input type="text" name="image" id="image">
    <!-- <h3>Image will be added later</h3> -->
     <br><br>
    <button type="submit">Submit</button>
    </form>

</body>
</html>