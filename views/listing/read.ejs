<% layout("/layouts/boilerplate") %>

    <body>
        <div class="center">
            <div class="card " style="border-radius: 0%; border-color: white;">
                <img src="<%= data.image %>" alt="Place Image" class="img-fluid">
                <div class="card-body">
                    <h5 class="card-title">
                        <%=data.title%>
                    </h5>
                    <p class="card-text">
                        <%= data.description %> <br>
                            &#8377; <%= data.price.toLocaleString("en-IN") %> <br>
                                <%= data.location %> <br>
                                    <%= data.country %> <br>
                                        <form method="post" action="/listing/<%=data._id %>/Delete?_method=delete">
                                            <a href="/listing/<%= data._id  %>/edit" class="btn btn-danger">Edit</a>
                                            <button type="submit" class="btn btn-primary">Delete</button>

                                        </form>
                    </p>
                </div>



            </div>
        </div>
    </body>